[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "LPDynR"]
	path = LPDynR
	url = https://github.com/xavi-rp/lpdynr
	shallow = true
	registered = true
[submodule "MinBAR"]
	path = MinBAR
	url = https://github.com/xavi-rp/minbar
	shallow = true
	registered = true
